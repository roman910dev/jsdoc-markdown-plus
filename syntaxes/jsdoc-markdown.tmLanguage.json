{
	"injectionSelector": "L:comment.block.documentation",
	"patterns": [
		{
			"include": "#jsdocbody"
		}
	],
	"repository": {
		"jsdocbody": {
			"contentName": "text.html.markdown meta.jsdoc.markdown",
			"begin": "(?<=/\\*\\*)([^*]|\\*(?!/))*$",
			"while": "(^|\\G)\\s*\\*(?!/)(?=([^*]|[*](?!/))*$)",
			"patterns": [
				{
					"include": "text.html.markdown#fenced_code_block_js"
				},
				{
					"include": "text.html.markdown#fenced_code_block_ts"
				},
				{
					"include": "text.html.markdown#fenced_code_block_unknown"
				},
				{
					"include": "#example"
				},
				{
					"include": "source.ts#docblock"
				},
				{
					"include": "source.js#docblock"
				},
				{
					"match": "\\G\\s*(#)\\s+(.+)$",
					"name": "markup.heading.markdown heading.1.markdown",
					"captures": {
						"1": {
							"name": "punctuation.definition.heading.markdown"
						},
						"2": {
							"name": "entity.name.section.markdown"
						}
					}
				},
				{
					"match": "\\G\\s*(##)\\s+(.+)$",
					"name": "markup.heading.markdown heading.2.markdown",
					"captures": {
						"1": {
							"name": "punctuation.definition.heading.markdown"
						},
						"2": {
							"name": "entity.name.section.markdown"
						}
					}
				},
				{
					"match": "\\G\\s*(###)\\s+(.+)$",
					"name": "markup.heading.markdown heading.3.markdown",
					"captures": {
						"1": {
							"name": "punctuation.definition.heading.markdown"
						},
						"2": {
							"name": "entity.name.section.markdown"
						}
					}
				},
				{
					"match": "\\G\\s*(####)\\s+(.+)$",
					"name": "markup.heading.markdown heading.4.markdown",
					"captures": {
						"1": {
							"name": "punctuation.definition.heading.markdown"
						},
						"2": {
							"name": "entity.name.section.markdown"
						}
					}
				},
				{
					"match": "\\G\\s*(#####)\\s+(.+)$",
					"name": "markup.heading.markdown heading.5.markdown",
					"captures": {
						"1": {
							"name": "punctuation.definition.heading.markdown"
						},
						"2": {
							"name": "entity.name.section.markdown"
						}
					}
				},
				{
					"match": "\\G\\s*(######)\\s+(.+)$",
					"name": "markup.heading.markdown heading.6.markdown",
					"captures": {
						"1": {
							"name": "punctuation.definition.heading.markdown"
						},
						"2": {
							"name": "entity.name.section.markdown"
						}
					}
				},
				{
					"match": "\\G\\s*([-+*])\\s+(.+)$",
					"name": "markup.list.unnumbered.markdown",
					"captures": {
						"1": {
							"name": "punctuation.definition.list.begin.markdown"
						},
						"2": {
							"name": "markup.list.item.markdown"
						}
					}
				},
				{
					"match": "\\G\\s*(\\d+\\.)(?=\\s)\\s+(.+)$",
					"name": "markup.list.numbered.markdown",
					"captures": {
						"1": {
							"name": "punctuation.definition.list.begin.markdown"
						},
						"2": {
							"name": "markup.list.item.markdown"
						}
					}
				},
				{
					"include": "text.html.markdown#inline"
				}
			]
		},
		"example": {
			"begin": "((@)example)\\s+(?=([^*]|[*](?!/))*$).*$",
			"while": "(^|\\G)\\s(?!@)(?=([^*]|[*](?!/))*$)",
			"beginCaptures": {
				"1": {
					"name": "storage.type.class.jsdoc"
				},
				"2": {
					"name": "punctuation.definition.block.tag.jsdoc"
				}
			},
			"contentName": "meta.embedded.block.example.source.ts",
			"patterns": [
				{
					"include": "source.ts"
				}
			]
		}
	},
	"scopeName": "injection.jsdoc.markdown"
}
