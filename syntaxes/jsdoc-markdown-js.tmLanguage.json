{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/refs/heads/master/tmlanguage.json",
	"injectionSelector": "L:comment.block.documentation.js",
	"name": "meta.jsdocMarkdownPlus",
	"patterns": [{ "include": "#jsdocbody" }],
	"repository": {
		"jsdocbody": {
			"contentName": "text.html.markdown meta.jsdocMarkdownPlus",
			"begin": "(?<=/\\*\\*)([^*]|\\*(?!/))*$",
			"while": "(^|\\G)\\s*(\\*|(/\\*\\*))(?!/)(?=([^*]|[*](?!/))*$)",
			"whileCaptures": {
				"0": { "name": "punctuation.definition.comment.jsdocMarkdownPlus.leading" }
			},
			"patterns": [
				{ "include": "text.html.markdown#fenced_code_block" },
				{ "include": "#example" },
				{ "include": "source.ts#docblock" },
				{ "include": "text.html.markdown#inline" },
				{ "include": "text.html.markdown#heading" },
				{ "include": "text.html.markdown#lists" },
				{ "include": "text.html.markdown#blockquote" }
			]
		},
		"example": {
			"begin": "((@)example)\\s+(?=([^*]|[*](?!/))*$).*$",
			"while": "(^|\\G)\\s(?!@)(?=([^*]|[*](?!/))*$)",
			"beginCaptures": {
				"1": {
					"name": "storage.type.class.jsdoc"
				},
				"2": {
					"name": "punctuation.definition.block.tag.jsdoc"
				}
			},
			"contentName": "meta.embedded.block.example.source.ts",
			"patterns": [{ "include": "source.js.jsx" }]
		}
	},
	"scopeName": "documentation.injection.js.jsx"
}
