{
	"name": "jsdoc-markdown-mvp",
	"displayName": "JSDoc Markdown MVP",
	"description": "Highlights Markdown syntax inside JSDoc comments for JS/TS/JSX/TSX.",
	"version": "0.0.1",
	"publisher": "local",
	"license": "MIT",
	"main": "./dist/extension.js",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Programming Languages"
	],
	"activationEvents": [
		"onLanguage:javascript",
		"onLanguage:typescript",
		"onLanguage:javascriptreact",
		"onLanguage:typescriptreact"
	],
	"scripts": {
		"build": "tsc -p .",
		"watch": "tsc -watch -p .",
		"vscode:prepublish": "npm run build"
	},
	"devDependencies": {
		"@types/vscode": "^1.85.0",
		"typescript": "^5.4.0"
	},
	"contributes": {
		"grammars": [
			{
				"scopeName": "documentation.injection.ts",
				"path": "./syntaxes/jsdoc-markdown-ts.tmLanguage.json",
				"injectTo": [
					"source.ts",
					"source.tsx"
				]
			},
			{
				"scopeName": "documentation.injection.js",
				"path": "./syntaxes/jsdoc-markdown-js.tmLanguage.json",
				"injectTo": [
					"source.js",
					"source.js.jsx"
				]
			}
		],
		"configuration": {
			"title": "JSDoc Markdown Style",
			"properties": {
				"jsdocMarkdownStyle.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable JSDoc block background styling."
				},
				"jsdocMarkdownStyle.backgroundColor": {
					"type": [
						"string",
						"null"
					],
					"default": "rgba(128, 128, 128, 0.08)",
					"description": "Background color for JSDoc blocks. Set to null or empty string to disable background."
				}
			}
		}
	}
}
