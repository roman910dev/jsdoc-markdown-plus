{
	"name": "jsdoc-markdown-plus",
	"displayName": "JSDoc Markdown Plus",
	"description": "Highlights Markdown syntax inside JSDoc comments for JS/TS/JSX/TSX.",
	"version": "0.1.0",
	"publisher": "roman910dev",
	"icon": "images/icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/roman910dev/jsdoc-markdown-plus.git"
	},
	"homepage": "https://github.com/roman910dev/jsdoc-markdown-plus#readme",
	"bugs": {
		"url": "https://github.com/roman910dev/jsdoc-markdown-plus/issues"
	},
	"license": "MIT",
	"type": "module",
	"main": "./dist/extension.js",
	"files": [
		"dist/**",
		"syntaxes/**",
		"images/**",
		"CHANGELOG.md",
		"README.md",
		"LICENSE"
	],
	"engines": {
		"vscode": "^1.85.0"
	},
	"keywords": [
		"jsdoc",
		"markdown",
		"typescript",
		"javascript",
		"syntax-highlighting",
		"textmate"
	],
	"categories": [
		"Programming Languages"
	],
	"activationEvents": [
		"onLanguage:javascript",
		"onLanguage:typescript",
		"onLanguage:javascriptreact",
		"onLanguage:typescriptreact"
	],
	"scripts": {
		"build": "tsc -p .",
		"watch": "tsc -watch -p .",
		"vscode:prepublish": "pnpm build"
	},
	"devDependencies": {
		"@types/vscode": "^1.85.0",
		"prettier": "^3.8.1",
		"typescript": "^5.4.0"
	},
	"contributes": {
		"grammars": [
			{
				"scopeName": "documentation.injection.ts",
				"path": "./syntaxes/jsdoc-markdown-ts.tmLanguage.json",
				"injectTo": [
					"source.ts",
					"source.tsx"
				]
			},
			{
				"scopeName": "documentation.injection.js",
				"path": "./syntaxes/jsdoc-markdown-js.tmLanguage.json",
				"injectTo": [
					"source.js",
					"source.js.jsx"
				]
			}
		],
		"configuration": {
			"title": "JSDoc Markdown Plus",
			"properties": {
				"jsdocMarkdownPlus.backgroundColor": {
					"type": [
						"string",
						"null"
					],
					"default": "rgba(0, 0, 0, 0.1)",
					"description": "Background color for JSDoc blocks. Set to null or empty string to disable background."
				}
			}
		}
	}
}
